<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - StudyNotes</title>

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- CSS do projeto -->
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>

<body>

    <!-- 🔥 NAVBAR PROFISSIONAL -->
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow">
            <div class="container">

                <a class="navbar-brand fw-bold" asp-controller="Notes" asp-action="Index">
                    📘 StudyNotes
                </a>

                <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#menu">
                    <span class="navbar-toggler-icon"></span>
                </button>

                <div class="collapse navbar-collapse" id="menu">
                    <ul class="navbar-nav ms-auto">

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Notes" asp-action="Index">Notas</a>
                        </li>

                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Notes" asp-action="Create">Nova Nota</a>
                        </li>

                    </ul>
                </div>

            </div>
        </nav>
    </header>

    <!-- 🔥 CONTEÚDO -->
    <div class="container mt-4">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <!-- 🔥 RODAPÉ -->
    <footer class="border-top footer text-muted mt-4">
        <div class="container text-center">
            &copy; 2026 - StudyNotes
        </div>
    </footer>

    <!-- Scripts -->
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>

    @await RenderSectionAsync("Scripts", required: false)

</body>
</html>